# DreamDEX mainnet — aggressive volume profile (SOMI:USDso, ~$50 wallet)
rpc_url: "https://api.infra.mainnet.somnia.network/"
chain_id: 5031
market_data_base: "https://api.dreamdex.io"
private_key_env: "PRIVATE_KEY"

market_symbol: "SOMI:USDso"
pool_address: "0x035De7403eac6872787779CCA7CCF1b4CDb61379"

volume_mode: true
trade_fraction: 0.95
reserve_quote_fraction: 0.02
reserve_native_wei: 50000000000000000

only_buy: false
only_sell: false
freq_sec: 8
min_loop_sec: 2
slippage_bps: 150
deadline_sec: 120
max_orders: null

bulk_mode: false
use_fok_for_bulk: false

priority_fee_gwei: 2
fallback_gas: 2000000
metrics_path: metrics.json
state_path: bot_state.json

# Optional: bot STOPS at this cumulative volume (18-decimal USDso). Omit to run forever.
# volume_target_quote_raw: 250000000000000000000000
